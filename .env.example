APP_ENV=production
APP_NAME=HRM Automation System
LOG_LEVEL=INFO

POSTGRES_DB=hrm
POSTGRES_USER=hrm_user
POSTGRES_PASSWORD=change_me_db_password
DATABASE_URL=postgresql+psycopg://hrm_user:change_me_db_password@db:5432/hrm

JWT_SECRET_KEY=change_me_to_long_random_secret_min_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

CORS_ORIGINS=http://localhost:3030,http://{서버IP}:3030

REDIS_URL=redis://hrm-redis:6379/0

NEXT_PUBLIC_API_BASE_URL=http://{서버IP}:8000

TEAMS_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=hrm-noreply@example.com

# SYS_CONFIG.IS_SECRET=TRUE 값(SMTP 비밀번호) 암호화 키 — `python -c "from cryptography.fernet
# import Fernet; print(Fernet.generate_key().decode())"`로 생성한 32바이트 base64 값
CONFIG_ENCRYPTION_KEY=

# ---- Provider AI (DeepSeek / OpenAI-compatible) -----------------------------
# LLM_PROVIDER controls which set of env vars is read.
# Supported values: deepseek (default), openai
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_ID=deepseek-chat
OPENAI_API_KEY=
