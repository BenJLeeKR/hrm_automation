# =============================================================================
# Human Resource Management Automation System — Local Development Environment
# =============================================================================
# Copy this file to .env and adjust values for your local setup.
#   cp .env.example .env
#
# NEVER commit the actual .env file to version control.
# =============================================================================

# ---- Application ------------------------------------------------------------
APP_ENV=production
APP_NAME=HRM Automation System
LOG_LEVEL=INFO

# ---- PostgreSQL (DATABASE) --------------------------------------------------
POSTGRES_DB=hrm
POSTGRES_USER=hrm_user
POSTGRES_PASSWORD=change_me_db_password
DATABASE_URL=postgresql+psycopg://hrm_user:change_me_db_password@db:5432/hrm
# 비밀번호 부분만 인코딩된 값으로 교체
DATABASE_URL=postgresql+psycopg://hrm_user:hrmpass%21%40%23%24@db:5432/hrm

# ---- JSON Web Token ---------------------------------------------------------
JWT_SECRET_KEY="q8Zt1Km4Fn7Jc3Hb6Lg0Vs2Dk5Nj8Rt1Yw4Xq7Mp0Zc="
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

CORS_ORIGINS=http://localhost:3030

REDIS_URL=redis://hrm-redis:6379/0

NEXT_PUBLIC_API_BASE_URL=

TEAMS_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=hrm-noreply@example.com

# SYS_CONFIG.IS_SECRET=TRUE 값(SMTP 비밀번호) 암호화 키 — `python -c "from cryptography.fernet
# import Fernet; print(Fernet.generate_key().decode())"`로 생성한 32바이트 base64 값
CONFIG_ENCRYPTION_KEY=

# 사원 등록 시 자동 생성되는 계정의 초기 비밀번호 — 미설정 시 서버가 무작위로 생성한다.
# 값을 지정하면 신규 계정 전부가 이 비밀번호로 발급되며(PWD_CHG_YN=TRUE라 최초 로그인 시
# 강제 변경됨), 8자 이상·영문+숫자+특수문자 포함 정책을 반드시 만족해야 한다.
EMPLOYEE_INITIAL_PASSWORD=

# ---- Provider AI (DeepSeek / OpenAI-compatible) -----------------------------
# LLM_PROVIDER controls which set of env vars is read.
# Supported values: deepseek (default), openai
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_ID=deepseek-chat
